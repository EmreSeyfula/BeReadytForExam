@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Генериране на кодове за възстановяване при двуфакторна автентикация (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <span class="glyphicon glyphicon-warning-sign"></span>
        <strong>Съхранявайте тези кодове на сигурно място.</strong>
    </p>
    <p>
        Ако загубите устройството си и нямате кодовете за възстановяване, ще изгубите достъп до акаунта си.
    </p>
    <p>
        Генерирането на нови кодове за възстановяване не променя ключовете, използвани в приложенията за автентикация. Ако искате да промените
        използвания ключ, трябва да <a asp-page="./ResetAuthenticator">нулирате ключовете на приложението за автентикация</a>.
    </p>
</div>
<div>
    <form method="post">
        <button class="btn btn-danger" type="submit">Генерирай кодове за възстановяване</button>
    </form>
</div>
