@page
@model Disable2faModel
@{
    ViewData["Title"] = "Деактивиране на двуфакторната автентикация (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>

<div class="alert alert-warning" role="alert">
    <p>
        <strong>Това действие само изключва двуфакторната автентикация.</strong>
    </p>
    <p>
        Изключването на 2FA не променя ключовете, използвани в приложенията за автентикация. Ако искате да смените
        използвания ключ, трябва да <a asp-page="./ResetAuthenticator">нулирате ключовете на приложението за автентикация</a>.
    </p>
</div>

<div>
    <form method="post">
        <button class="btn btn-danger" type="submit">Деактивиране на 2FA</button>
    </form>
</div>
