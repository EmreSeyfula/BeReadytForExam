@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Изпращане на ново потвърждение по имейл";
}

<h1>@ViewData["Title"]</h1>
<h2>Въведете своя имейл адрес.</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" aria-required="true" placeholder="ime@primer.com" />
                <label asp-for="Input.Email" class="form-label">Имейл адрес</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Изпрати отново</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
