@model BeReadyForExam.ViewModel.Teacher.TeacherDashboardViewModel

@{
    ViewData["Title"] = "Учителско табло";
}

<div class="container mt-4">
    <h2 class="mb-4">Учителско табло</h2>

    <div class="d-flex gap-2 mb-4">
        <a asp-controller="Exam" asp-action="Index" class="btn btn-primary">Управление на тестове</a>
        <a asp-controller="Question" asp-action="Index" class="btn btn-outline-primary">Въпроси</a>
        <a asp-controller="Topics" asp-action="Index" class="btn btn-outline-secondary">Теми</a>
        <a asp-controller="Subjects" asp-action="Index" class="btn btn-outline-dark">Предмети</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4 col-lg-2">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted">Общо тестове</div>
                    <div class="fs-3 fw-bold">@Model.TotalExams</div>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-2">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted">Активни тестове</div>
                    <div class="fs-3 fw-bold">@Model.ActiveExams</div>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-2">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted">Въпроси</div>
                    <div class="fs-3 fw-bold">@Model.TotalQuestions</div>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-2">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted">Опити</div>
                    <div class="fs-3 fw-bold">@Model.TotalAttempts</div>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-2">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted">Завършени</div>
                    <div class="fs-3 fw-bold">@Model.CompletedAttempts</div>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-2">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted">Среден резултат</div>
                    <div class="fs-3 fw-bold">@Model.AverageScorePercent.ToString("F1")%</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">Последни опити</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Тест</th>
                        <th>Потребител</th>
                        <th>Резултат</th>
                        <th>Започнат</th>
                        <th>Завършен</th>
                        <th>Подробности</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentAttempts)
                    {
                            <tr>
                                <td>@item.ExamTitle</td>
                                <td>@item.UserId</td>
                                <td>@item.CorrectCount / @item.TotalQuestions (@item.ScorePercent.ToString("F1")%)</td>
                                <td>@item.StartedAt.ToLocalTime().ToString("g")</td>
                                <td>@(item.FinishedAt.HasValue ? item.FinishedAt.Value.ToLocalTime().ToString("g") : "-")</td>
                                <td>
                                    <a asp-controller="Exam" asp-action="Result" asp-route-attemptId="@item.AttemptId" class="btn btn-sm btn-outline-primary">
                                        Виж
                                    </a>
                                </td>
                            </tr>
                    }

                    @if (!Model.RecentAttempts.Any())
                    {
                            <tr>
                                <td colspan="6" class="text-center py-4">Все още няма опити.</td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>