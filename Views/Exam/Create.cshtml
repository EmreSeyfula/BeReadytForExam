@model BeReadyForExam.Models.Exam

@{
    ViewData["Title"] = "Създаване на тест";
}

<div class="container mt-4" style="max-width: 720px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Създаване на тест</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">⬅ Назад към тестовете</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Заглавие</label>
                    <input asp-for="Title" class="form-control" placeholder="Пример: Финален тест по математика" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                 <div class="mb-3">
                   <label class="form-label">Предмет</label>
                   <select id="subjectFilter" asp-items="ViewBag.Subjects" class="form-select">
                       <option value="">-- Избери предмет --</option>
                   </select>
               </div>
                <div class="mb-3">
                    <label asp-for="TopicId" class="form-label">Тема</label>
                    <select asp-for="TopicId" asp-items="ViewBag.Topics" class="form-select">
                        <option value="0">-- Избери тема --</option>
                    </select>
                    <span asp-validation-for="TopicId" class="text-danger"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="QuestionsCount" class="form-label">Брой въпроси</label>
                        <input asp-for="QuestionsCount" class="form-control" />
                        <span asp-validation-for="QuestionsCount" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TimeLimitMinutes" class="form-label">Ограничение за време (минути)</label>
                        <input asp-for="TimeLimitMinutes" class="form-control" />
                        <span asp-validation-for="TimeLimitMinutes" class="text-danger"></span>
                        <div class="form-text">Остави празно, ако няма ограничение.</div>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Description" class="form-label">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Не е задължително описание за учениците..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-check mt-3">
                    <input asp-for="RandomizeQuestions" class="form-check-input" />
                    <label asp-for="RandomizeQuestions" class="form-check-label">Разбъркай въпросите</label>
                </div>

                <div class="form-check mt-2">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Активен</label>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Запази</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}