@model BeReadyForExam.ViewModel.Exam.TakeExamViewModel

@{
    ViewData["Title"] = "Решаване на тест";
}

<div class="container mt-4" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Решаване на тест</h2>
        <a asp-action="Available" class="btn btn-outline-secondary">Назад към тестовете</a>
    </div>

    @if (Model.TimeLimitMinutes.HasValue)
    {
            <div class="alert alert-warning d-flex justify-content-between align-items-center">
                <div>
                    <strong>Ограничение:</strong> @Model.TimeLimitMinutes мин
                </div>
                <div>
                    <strong>Оставащо време:</strong> <span id="timer">--:--</span>
                </div>
            </div>
    }

    @if (Model.IsExpired)
    {
            <div class="alert alert-danger">
                Времето изтече. Изпрати теста.
            </div>
    }

    <form asp-action="Submit" method="post" id="examForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="AttemptId" value="@Model.AttemptId" />

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
                <div class="card shadow-sm mb-3">
                    <div class="card-body">
                        <div class="fw-semibold mb-3">
                        @(i + 1). @Model.Questions[i].Text
                        </div>

                        <input type="hidden" name="Answers[@i].QuestionId" value="@Model.Questions[i].QuestionId" />

                    @foreach (var opt in Model.Questions[i].Options)
                    {
                                <div class="form-check mb-2">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="Answers[@i].SelectedOptionId"
                                           value="@opt.OptionId"
                                           id="q@(i)_o@(opt.OptionId)" />
                                    <label class="form-check-label" for="q@(i)_o@(opt.OptionId)">
                                @opt.Text
                                    </label>
                                </div>
                    }
                    </div>
                </div>
        }

        <button type="submit" class="btn btn-success w-100">
            Предай теста
        </button>
    </form>
</div>

@section Scripts {
    @if (Model.SecondsRemaining.HasValue)
    {
                <script>
                    let secondsRemaining = @Model.SecondsRemaining.Value;
                    const timerEl = document.getElementById("timer");
                    const examForm = document.getElementById("examForm");

                    function formatTime(totalSeconds) {
                        const minutes = Math.floor(totalSeconds / 60);
                        const seconds = totalSeconds % 60;
                        return `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                    }

                    function updateTimer() {
                        if (!timerEl) return;

                        timerEl.textContent = formatTime(Math.max(0, secondsRemaining));

                        if (secondsRemaining <= 0) {
                            examForm.submit();
                            return;
                        }

                        secondsRemaining--;
                    }

                    updateTimer();
                    setInterval(updateTimer, 1000);
                </script>
    }
}