@model IEnumerable<BeReadyForExam.ViewModel.Exam.TeacherExamRowViewModel>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Exams (Teacher)</h2>
        <a asp-action="Create" class="btn btn-success">Create Exam</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Topic</th>
                        <th>Active</th>
                        <th>Configured</th>
                        <th>Questions in DB</th>
                        <th style="width:320px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@e.Title</td>
                            <td>@e.TopicName</td>
                            <td>
                                @if (e.IsActive)
                                {
                                        <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                        <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@e.ConfiguredQuestionsCount</td>
                            <td>
                                @e.ActualQuestionsInBank
                                @if (e.ActualQuestionsInBank < e.ConfiguredQuestionsCount)
                                {
                                        <span class="text-danger small ms-2">(not enough)</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-controller="Question"
                                   asp-action="Index"
                                   asp-route-examId="@e.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Manage Questions
                                </a>

                                <a asp-controller="Question"
                                   asp-action="Create"
                                   asp-route-examId="@e.Id"
                                   class="btn btn-sm btn-outline-success">
                                    Add Question
                                </a>

                                <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>