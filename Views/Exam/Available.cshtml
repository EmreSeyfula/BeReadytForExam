@model IEnumerable<BeReadyForExam.Models.Exam>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Налични тестове</h2>
        <a asp-action="MyHistory" class="btn btn-outline-secondary">Моята история</a>
    </div>

    @if (!Model.Any())
    {
            <div class="alert alert-info">
                В момента няма налични тестове.
            </div>
    }
    else
    {
            <div class="row g-3">
            @foreach (var exam in Model)
            {
                        <div class="col-md-6 col-lg-4">
                            <div class="card shadow-sm h-100">
                                <div class="card-body d-flex flex-column">
                                    <div class="text-muted small mb-1">
                                        Тема: <strong>@exam.Topic?.Name</strong>
                                    </div>

                                    <h5 class="card-title">@exam.Title</h5>

                            @if (!string.IsNullOrWhiteSpace(exam.Description))
                            {
                                            <p class="card-text text-muted">@exam.Description</p>
                            }

                                    <div class="mt-auto">
                                        <div class="small text-muted mb-2">
                                            Въпроси: <strong>@exam.QuestionsCount</strong>
                                    @if (exam.TimeLimitMinutes.HasValue)
                                    {
                                                    <span> • Време: <strong>@exam.TimeLimitMinutes</strong> мин</span>
                                    }
                                            <span> • Разбъркване: <strong>@(exam.RandomizeQuestions ? "Да" : "Не")</strong></span>
                                        </div>

                                        <a asp-action="Start"
                                           asp-route-examId="@exam.Id"
                                           class="btn btn-success w-100">
                                            Започни теста
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
            }
            </div>
    }
</div>