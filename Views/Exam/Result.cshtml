@model BeReadyForExam.ViewModel.Exam.ExamResultViewModel

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Exam Result</h2>
            <div class="text-muted">@Model.TopicName</div>
        </div>
        <a asp-action="MyHistory" class="btn btn-outline-secondary">My History</a>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Grade</div>
                    <div class="display-6 fw-bold">@Model.Grade.ToString("0.00")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Score</div>
                    <div class="display-6 fw-bold">@Model.ScorePercent.ToString("0.0")%</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Correct</div>
                    <div class="display-6 fw-bold">@Model.CorrectCount / @Model.TotalQuestions</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Time</div>
                    <div class="fw-semibold">
                        @Model.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        <div class="text-muted small">
                            @(Model.FinishedAt == null ? "Not finished" : Model.FinishedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-header bg-dark text-white">
            Wrong Answers
        </div>
        <div class="card-body">
            @if (Model.WrongAnswers.Count == 0)
            {
                    <div class="alert alert-success mb-0">
                        Perfect! No wrong answers 🎉
                    </div>
            }
            else
            {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Question</th>
                                    <th>Your Answer</th>
                                    <th>Correct Answer</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var w in Model.WrongAnswers)
                            {
                                    <tr>
                                        <td>@w.QuestionText</td>
                                        <td class="text-danger">@w.SelectedOptionText</td>
                                        <td class="text-success">@w.CorrectOptionText</td>
                                    </tr>
                            }
                            </tbody>
                        </table>
                    </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Topics" asp-action="Index" class="btn btn-primary">Back to Topics</a>
    </div>
</div>