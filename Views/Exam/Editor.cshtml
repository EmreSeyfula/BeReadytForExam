@model BeReadyForExam.ViewModel.Exam.ExamEditorViewModel

@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Редакция на тест" : "Създаване на тест";
}

<div class="container mt-4" style="max-width: 1100px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex gap-2 align-items-center">
            @{
                ViewData["BackController"] = "Exam";
                ViewData["BackAction"] = "Index";
                ViewData["BackText"] = "Назад към тестовете";
            }
            <partial name="_BackButton" />
            <h2 class="mb-0">@ViewData["Title"]</h2>
        </div>
    </div>

    <partial name="_ExamEditorForm" model="Model" />
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}