@model BeReadyForExam.Models.Exam
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Редакция на тест</h2>
    @{
        ViewData["BackController"] = "Exam";
        ViewData["BackAction"] = "Index";
        ViewData["BackText"] = "Назад към тестовете";
    }
    <partial name="_BackButton" />
</div>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Заглавие</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Предмет</label>
        <select id="subjectFilter" asp-items="ViewBag.Subjects" class="form-select">
            <option value="">-- Избери предмет --</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Тема</label>
        <select asp-for="TopicId"
                asp-items="ViewBag.Topics"
                class="form-select"
                id="topicSelect"
                data-selected-value="@Model.TopicId">
            <option value="0">-- Избери тема --</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Брой въпроси</label>
        <input asp-for="QuestionsCount" class="form-control" />
    </div>

    <div class="form-check">
        <input asp-for="RandomizeQuestions" class="form-check-input" />
        <label class="form-check-label">Разбъркай въпросите</label>
    </div>

    <div class="form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label class="form-check-label">Активен</label>
    </div>

   <div class="d-flex gap-2 mt-3">
    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="Index" class="btn btn-secondary">Отказ</a>
</div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            window.initSubjectTopicExamFilters?.({
                subjectSelector: "#subjectFilter",
                topicSelector: "#topicSelect",
                topicsUrl: "@Url.Action("BySubject", "Topics")",
                topicPlaceholder: "-- Избери тема --",
                topicEmptyValue: "0"
            });
        });
    </script>
}
