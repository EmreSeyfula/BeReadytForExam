@model IEnumerable<BeReadyForExam.Models.Subject>

@{
    ViewData["Title"] = "Предмети";
}

<h2>Предмети</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Създай нов предмет</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Име</th>
            <th>Описание</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редактирай</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Изтрий</a>
                    </td>
                </tr>
        }
    </tbody>
</table>