@model IEnumerable<BeReadyForExam.Models.Topic>

<div class="management-page topic-management-page fade-in-up">
    <div class="d-flex gap-2 align-items-center mb-3">
        @{
            ViewData["BackController"] = "Teacher";
            ViewData["BackAction"] = "Dashboard";
            ViewData["BackText"] = "Назад към таблото";
        }
        <partial name="_BackButton" />
    </div>

    <div class="management-hero mb-4">
        <div class="management-hero-content">
            <div>
                <span class="management-tag">Структура</span>
                <h1 class="management-title">Теми</h1>
                <p class="management-subtitle">
                    Подреди съдържанието по теми, за да е по-лесно създаването на тестове и поддържането на учебната структура.
                </p>
            </div>

            <a asp-action="Create" class="btn btn-primary management-hero-btn">Създай тема</a>
        </div>
    </div>

    <div class="card management-table-card shadow-sm">
        <div class="card-header management-table-header">
            <div>
                <h4 class="mb-1">Списък с теми</h4>
                <div class="management-table-subtitle">Всички активни и неактивни теми по предмети.</div>
            </div>
        </div>

        <div class="card-body table-responsive">
            <table class="table management-table align-middle">
                <thead>
                    <tr>
                        <th>Име</th>
                        <th>Предмет</th>
                        <th>Статус</th>
                        <th style="width: 240px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>
                                <td>@item.Subject?.Name</td>
                                <td>
                                    <span class="status-pill @(item.IsActive ? "status-active" : "status-inactive")">
                                        @(item.IsActive ? "Активна" : "Неактивна")
                                    </span>
                                </td>
                                <td>
                                    <div class="management-actions">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Редактирай</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Изтрий</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="management-empty-state">Все още няма създадени теми.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
