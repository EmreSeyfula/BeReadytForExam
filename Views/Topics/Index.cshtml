@model IEnumerable<BeReadyForExam.Models.Topic>

@{
    ViewData["Title"] = "Topics";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Topics</h2>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary">Create Topic</a>
            <a asp-controller="Question" asp-action="Index" class="btn btn-outline-secondary">Questions</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Subject?.Name</td>
                                <td>
                                @if (item.IsActive)
                                {
                                            <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                            <span class="badge bg-secondary">Inactive</span>
                                }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                </td>
                            </tr>
                    }

                    @if (!Model.Any())
                    {
                            <tr>
                                <td colspan="4" class="text-center py-4">No topics yet.</td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>