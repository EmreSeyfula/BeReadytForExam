@model IEnumerable<BeReadyForExam.Models.Topic>

<h2 class="mb-4">Теми</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Създай тема</a>
<a class="btn btn-primary mb-3" asp-controller="Question" asp-action="Index">Въпроси</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Име</th>
            <th>Предмет</th>
            <th>Активна</th>
            <th style="width:180px;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Subject?.Name</td>
                            <td>@(item.IsActive ? "Да" : "Не")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редактирай</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Изтрий</a>
                            </td>
                        </tr>
            }
        }
        else
        {
                <tr>
                    <td colspan="4" class="text-center py-4">Все още няма теми.</td>
                </tr>
        }
    </tbody>
</table>