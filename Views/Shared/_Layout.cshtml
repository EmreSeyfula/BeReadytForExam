<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BeReadyForExam</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-graduation-cap me-2"></i>BeReadyForExam
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Начало
                        </a>
                    </li>
                    @if (User.Identity.IsAuthenticated)
                    {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Subjects" asp-action="Index">
                                    <i class="fas fa-book me-1"></i>Предмети
                                </a>
                            </li>
                            <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Teacher" asp-action="Dashboard">
                                    <i class="fas fa-chart-line me-1"></i>Табло
                                </a>
                            </li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="fas fa-graduation-cap me-2"></i>BeReadyForExam</h5>
                    <p>Подгответе се успешно за вашите изпити с нашата платформа</p>
                </div>
                <div class="col-md-3">
                    <h6>Бързи връзки</h6>
                    <ul class="list-unstyled">
                        <li><a href="#">За нас</a></li>
                        <li><a href="#">Контакти</a></li>
                        <li><a href="#">Политика за поверителност</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6>Последвайте ни</h6>
                    <div class="social-links">
                        <a href="#" class="me-2"><i class="fab fa-facebook fa-lg"></i></a>
                        <a href="#" class="me-2"><i class="fab fa-twitter fa-lg"></i></a>
                        <a href="#" class="me-2"><i class="fab fa-linkedin fa-lg"></i></a>
                        <a href="#"><i class="fab fa-github fa-lg"></i></a>
                    </div>
                </div>
            </div>
            <hr class="mt-3" style="background-color: rgba(249,247,240,0.2);">
            <div class="text-center">
                <small>&copy; @DateTime.Now.Year - BeReadyForExam - Всички права запазени</small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>