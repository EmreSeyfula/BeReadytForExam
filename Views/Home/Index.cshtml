@{
    ViewData["Title"] = "Начало";
}

<div class="text-center">
    <h1 class="display-4">Добре дошъл</h1>
    <p>Платформа за подготовка за изпити, тестове и упражнения.</p>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
            <div class="row g-3 justify-content-center">
            @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
            {
                        <div class="col-md-4">
                            <a asp-controller="Teacher" asp-action="Dashboard" class="btn btn-primary w-100 py-3">
                                Учителско табло
                            </a>
                        </div>

                        <div class="col-md-4">
                            <a asp-controller="Exam" asp-action="Index" class="btn btn-outline-primary w-100 py-3">
                                Управление на тестове
                            </a>
                        </div>

                        <div class="col-md-4">
                            <a asp-controller="Question" asp-action="Index" class="btn btn-outline-secondary w-100 py-3">
                                Управление на въпроси
                            </a>
                        </div>

                        <div class="col-md-4">
                            <a asp-controller="Topics" asp-action="Index" class="btn btn-outline-dark w-100 py-3">
                                Управление на теми
                            </a>
                        </div>

                        <div class="col-md-4">
                            <a asp-controller="Subjects" asp-action="Index" class="btn btn-outline-dark w-100 py-3">
                                Управление на предмети
                            </a>
                        </div>
            }

                <div class="col-md-4">
                    <a asp-controller="Exam" asp-action="Available" class="btn btn-success w-100 py-3">
                        Налични тестове
                    </a>
                </div>

                <div class="col-md-4">
                    <a asp-controller="Exam" asp-action="MyHistory" class="btn btn-outline-success w-100 py-3">
                        Моята история
                    </a>
                </div>
            </div>
    }
    else
    {
            <div class="text-center">
                <p class="mb-3">Моля, влез в профила си, за да използваш платформата.</p>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary me-2">Вход</a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-primary">Регистрация</a>
            </div>
    }
</div>