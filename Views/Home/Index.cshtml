@model BeReadyForExam.ViewModel.Home.HomeIndexViewModel
@{
    ViewData["Title"] = "Начало";
}

<div class="hero-section fade-in-up">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-4 fw-bold mb-4">
                    <i class="fas fa-brain me-2"></i>
                    Бъдете готови за изпитите!
                </h1>
                <p class="lead mb-4">
                    Интерактивна платформа за подготовка с въпроси, теми и предмети.
                    Учете ефективно и постигнете отлични резултати!
                </p>
                @if (!Model.IsAuthenticated)
                {
                    <div class="d-flex gap-3">
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg">
                            <i class="fas fa-user-plus me-2"></i>Регистрация
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary btn-lg">
                            <i class="fas fa-sign-in-alt me-2"></i>Вход
                        </a>
                    </div>
                }
                else
                {
                    <a class="btn btn-primary btn-lg rounded-pill px-4"
                       asp-controller="Exam"
                       asp-action="Available">
                        <i class="fas fa-play me-2"></i>Започнете сега
                    </a>
                }
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="text-center">
                    <i class="fas fa-chalkboard-teacher" style="font-size: 200px; color: rgba(255,255,255,0.2);"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card text-center fade-in-up" style="animation-delay: 0.1s;">
                <div class="stat-icon">
                    <i class="fas fa-book-open"></i>
                </div>
                <div class="stat-number">@Model.SubjectsCount</div>
                <div class="stat-label">Предмети</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card text-center fade-in-up" style="animation-delay: 0.2s;">
                <div class="stat-icon">
                    <i class="fas fa-question-circle"></i>
                </div>
                <div class="stat-number">@Model.QuestionsCount</div>
                <div class="stat-label">Въпроси</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card text-center fade-in-up" style="animation-delay: 0.3s;">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-number">@Model.UsersCount</div>
                <div class="stat-label">Потребители</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-4">
        <div class="col-md-6">
            <div class="card h-100 fade-in-up">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-star me-2"></i>Как работи?</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex mb-4">
                        <div class="me-3">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                1
                            </div>
                        </div>
                        <div>
                            <h5>Изберете предмет</h5>
                            <p class="text-muted">Изберете от различните налични предмети за подготовка</p>
                        </div>
                    </div>
                    <div class="d-flex mb-4">
                        <div class="me-3">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                2
                            </div>
                        </div>
                        <div>
                            <h5>Разгледайте темите</h5>
                            <p class="text-muted">Всяка тема съдържа структурирано съдържание за учене</p>
                        </div>
                    </div>
                    <div class="d-flex">
                        <div class="me-3">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                3
                            </div>
                        </div>
                        <div>
                            <h5>Решавайте тестове</h5>
                            <p class="text-muted">Тествайте знанията си с интерактивни въпроси</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 fade-in-up">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-chart-line me-2"></i>@(Model.IsAdmin ? "Общ преглед" : "Вашият прогрес")</h4>
                </div>
                <div class="card-body">
                    @if (Model.IsAuthenticated)
                    {
                        @if (Model.HasProgressData)
                        {
                            <div class="mb-3">
                                <p class="text-muted mb-4">@Model.ProgressDescription</p>
                            </div>
                            <div class="mb-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@Model.ProgressTitle</span>
                                    <span class="fw-bold">@Model.ProgressValueText</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar" style="width: @Model.ProgressPercent.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                </div>
                            </div>
                            <div class="mb-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@Model.SecondaryMetricLabel</span>
                                    <span class="fw-bold">@Model.SecondaryMetricValueText</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar" style="width: @Model.SecondaryMetricPercent.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                </div>
                            </div>
                            <a asp-controller="@Model.DetailsController" asp-action="@Model.DetailsAction" class="btn btn-primary w-100">
                                <i class="fas fa-chart-simple me-2"></i>@Model.DetailsButtonText
                            </a>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-chart-pie" style="font-size: 50px; color: var(--primary-teal);"></i>
                                <p class="mt-3 mb-4">
                                    @(Model.IsAdmin
                                        ? "Все още няма достатъчно завършени опити за обща статистика."
                                        : "Все още няма достатъчно решени тестове, за да покажем личен прогрес.")
                                </p>
                                <a asp-controller="@Model.DetailsController" asp-action="@Model.DetailsAction" class="btn btn-primary">
                                    @Model.DetailsButtonText
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-lock" style="font-size: 50px; color: var(--primary-teal);"></i>
                            <p class="mt-3">Влезте в профила си, за да видите прогреса</p>
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary">
                                Вход
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12 text-center">
            <div class="card bg-gradient fade-in-up" style="background: linear-gradient(135deg, var(--primary-dark), var(--primary-blue)); color: white;">
                <div class="card-body py-5">
                    <h3 class="mb-3">Готови ли сте да започнете?</h3>
                    <p class="mb-4">Присъединете се към хилядите ученици, които вече се подготвят с нас</p>
                    @if (!Model.IsAuthenticated)
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg">
                            <i class="fas fa-rocket me-2"></i>Започнете безплатно
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
