@model BeReadyForExam.ViewModel.QuestionCreateViewModel

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Question</label>
        <input asp-for="Text" class="form-control" />
    </div>

    <div class="mb-4">
        <label class="form-label">Test</label>
        <select asp-for="ExamId" asp-items="Model.Exams" class="form-select">
            <option value="0">-- Select Test --</option>
        </select>
    </div>

    <hr />
    <h5 class="mb-3">Options</h5>

    <div id="optionsContainer">
        @for (int i = 0; i < Model.Options.Count; i++)
        {
                <div class="row mb-2 option-row">
                    <input type="hidden" name="Options[@i].Id" value="@Model.Options[i].Id" />

                    <div class="col-md-8">
                        <input name="Options[@i].Text"
                               value="@Model.Options[i].Text"
                               class="form-control"
                               placeholder="Option text" />
                    </div>

                    <div class="col-md-2 form-check mt-2">
                        <input type="checkbox"
                               name="Options[@i].IsCorrect"
                               value="true"
                               class="form-check-input"
                    @(Model.Options[i].IsCorrect ? "checked" : "") />
                        <label class="form-check-label">Correct</label>
                    </div>

                    <div class="col-md-2">
                        <button type="button" class="btn btn-danger remove-option">❌</button>
                    </div>
                </div>
        }
    </div>

    <button type="button" id="addOption" class="btn btn-secondary mt-2">➕ Add Option</button>

    <hr />
    <button type="submit" class="btn btn-success w-100">💾 Save Changes</button>
</form>

@section Scripts {
    <script>
        let optionIndex = @Model.Options.Count;

        document.getElementById("addOption").addEventListener("click", function () {
            const container = document.getElementById("optionsContainer");

            const html = `
            <div class="row mb-2 option-row">
                <input type="hidden" name="Options[${optionIndex}].Id" value="0" />

                <div class="col-md-8">
                    <input name="Options[${optionIndex}].Text" class="form-control" placeholder="Option text" />
                </div>

                <div class="col-md-2 form-check mt-2">
                    <input type="checkbox" name="Options[${optionIndex}].IsCorrect" value="true" class="form-check-input" />
                    <label class="form-check-label">Correct</label>
                </div>

                <div class="col-md-2">
                    <button type="button" class="btn btn-danger remove-option">❌</button>
                </div>
            </div>`;

            container.insertAdjacentHTML("beforeend", html);
            optionIndex++;
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-option")) {
                e.target.closest(".option-row").remove();
            }
        });
    </script>
}