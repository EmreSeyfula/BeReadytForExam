@using BeReadyForExam.ViewModel
@model QuestionCreateViewModel

@{
    ViewData["Title"] = "Редакция на въпрос";
}


<div class="container mt-4" style="max-width: 900px;">
    <div class="card shadow-sm">
        <div class="card-header">
            <h3 class="mb-0">Редакция на въпрос</h3>
        </div>
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Text" class="form-label">Текст на въпроса</label>
                    <input asp-for="Text" class="form-control" />
                    <span asp-validation-for="Text" class="text-danger"></span>
                </div>

                  <div class="row g-3 mb-3">
                 <div class="col-md-4">
                     <label asp-for="SubjectId" class="form-label">Предмет</label>
                     <select asp-for="SubjectId" asp-items="Model.Subjects" class="form-select" id="subjectSelect">
                         <option value="">-- Избери предмет --</option>
                     </select>
                 </div>
             
                 <div class="col-md-4">
                     <label asp-for="TopicId" class="form-label">Тема</label>
                     <select asp-for="TopicId" asp-items="Model.Topics" class="form-select" id="topicSelect">
                         <option value="">-- Избери тема --</option>
                     </select>
                 </div>
             
                 <div class="col-md-4">
                     <label asp-for="ExamId" class="form-label">Тест</label>
                     <select asp-for="ExamId" asp-items="Model.Exams" class="form-select" id="examSelect">
                         <option value="0">-- Избери тест --</option>
                     </select>
                     <span asp-validation-for="ExamId" class="text-danger"></span>
                 </div>
              </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Активен въпрос</label>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Отговори</h5>
                    <button type="button" id="addOption" class="btn btn-outline-secondary btn-sm">
                        Добави отговор
                    </button>
                </div>

                <div id="optionsContainer">
                    @for (int i = 0; i < Model.Options.Count; i++)
                    {
                            <div class="row g-2 align-items-center mb-2 option-row">
                              

                                <div class="col-md-8">
                                    <input name="Options[@i].Text"
                                           value="@Model.Options[i].Text"
                                           class="form-control"
                                           placeholder="Текст на отговора" />
                                </div>

                                   <div class="col-md-2">
                                <div class="form-check mt-2">
                                    <input type="checkbox"
                                           name="Options[@i].IsCorrect"
                                           value="true"
                                           class="form-check-input"
                                                            @(Model.Options[i].IsCorrect ? "checked" : "") />
                                    <input type="hidden" name="Options[@i].IsCorrect" value="false" />
                                    <label class="form-check-label">Верен</label>
                                </div>
                            </div>

                                <div class="col-md-2 text-end">
                                    <button type="button" class="btn btn-outline-danger remove-option">Премахни</button>
                                </div>
                            </div>
                    }
                </div>

                <hr />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Запази промените</button>
                    <a asp-action="Index" asp-route-examId="@Model.ExamId" class="btn btn-secondary">Назад</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const subjectSelect = document.getElementById("subjectSelect");
        const topicSelect = document.getElementById("topicSelect");
        const examSelect = document.getElementById("examSelect");

        const allTopicOptions = Array.from(topicSelect.options).map(o => ({
            value: o.value,
            text: o.text,
            subjectId: o.getAttribute("data-subject")
        }));

        const allExamOptions = Array.from(examSelect.options).map(o => ({
            value: o.value,
            text: o.text,
            subjectId: o.getAttribute("data-subject"),
            topicId: o.getAttribute("data-topic")
        }));

        function refreshTopics() {
            const selectedSubject = subjectSelect.value;
            const currentTopic = topicSelect.value;

            topicSelect.innerHTML = '<option value="">-- Избери тема --</option>';

            allTopicOptions.forEach(opt => {
                if (!opt.value) return;
                if (!selectedSubject || opt.subjectId === selectedSubject) {
                    const option = document.createElement("option");
                    option.value = opt.value;
                    option.text = opt.text;
                    option.setAttribute("data-subject", opt.subjectId || "");
                    if (opt.value === currentTopic) option.selected = true;
                    topicSelect.appendChild(option);
                }
            });
        }

        function refreshExams() {
            const selectedSubject = subjectSelect.value;
            const selectedTopic = topicSelect.value;
            const currentExam = examSelect.value;

            examSelect.innerHTML = '<option value="0">-- Избери тест --</option>';

            allExamOptions.forEach(opt => {
                if (!opt.value) return;

                const subjectOk = !selectedSubject || opt.subjectId === selectedSubject;
                const topicOk = !selectedTopic || opt.topicId === selectedTopic;

                if (subjectOk && topicOk) {
                    const option = document.createElement("option");
                    option.value = opt.value;
                    option.text = opt.text;
                    option.setAttribute("data-subject", opt.subjectId || "");
                    option.setAttribute("data-topic", opt.topicId || "");
                    if (opt.value === currentExam) option.selected = true;
                    examSelect.appendChild(option);
                }
            });
        }

        subjectSelect.addEventListener("change", function () {
            topicSelect.value = "";
            examSelect.value = "0";
            refreshTopics();
            refreshExams();
        });

        topicSelect.addEventListener("change", function () {
            examSelect.value = "0";
            refreshExams();
        });

        refreshTopics();
        refreshExams();
    });
</script>
}