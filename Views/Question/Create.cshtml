@using BeReadyForExam.ViewModel
@model QuestionCreateViewModel

@{
    ViewData["Title"] = "Създаване на въпрос";
}


<div class="container mt-4" style="max-width: 900px;">
    <div class="card shadow-sm">
        <div class="card-header">
            <h3 class="mb-0">Създаване на въпрос</h3>
        </div>
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Text" class="form-label">Съдържание на въпроса</label>
                    <input asp-for="Text" class="form-control" />
                    <span asp-validation-for="Text" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ExamId" class="form-label">Тест</label>
                    <select asp-for="ExamId" asp-items="Model.Exams" class="form-select">
                        <option value="0">-- Избери тест --</option>
                    </select>
                    <span asp-validation-for="ExamId" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Активен въпрос</label>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Отговори</h5>
                    <button type="button" id="addOption" class="btn btn-outline-secondary btn-sm">
                        Добави отговор
                    </button>
                </div>

                <div id="optionsContainer">
                    @for (int i = 0; i < Model.Options.Count; i++)
                    {
                            <div class="row g-2 align-items-center mb-2 option-row">
                                <input type="hidden" name="Options[@i].Id" value="@Model.Options[i].Id" />

                                <div class="col-md-8">
                                    <input name="Options[@i].Text"
                                           value="@Model.Options[i].Text"
                                           class="form-control"
                                           placeholder="Текст на отговора" />
                                </div>

                                <div class="col-md-2">
                                    <div class="form-check mt-2">
                                        
                                        <input type="checkbox"
                                               name="Options[@i].IsCorrect"
                                               value="true"
                                               class="form-check-input"
                                    @(Model.Options[i].IsCorrect ? "checked" : "") />
                                        <input type="hidden" name="Options[@i].IsCorrect" value="false" />
                                        <label class="form-check-label">Верен</label>
                                    </div>
                                </div>

                                <div class="col-md-2 text-end">
                                    <button type="button" class="btn btn-outline-danger remove-option">Премахни</button>
                                </div>
                            </div>
                    }
                </div>

                <hr />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Запази въпроса</button>
                    <a asp-action="Index" asp-route-examId="@Model.ExamId" class="btn btn-secondary">Назад</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />

        <script>
            const optionsContainer = document.getElementById("optionsContainer");
            const addOptionBtn = document.getElementById("addOption");

            function reindexOptions() {
                const rows = optionsContainer.querySelectorAll(".option-row");

                rows.forEach((row, index) => {
                    const hiddenId = row.querySelector('input[type="hidden"][name*=".Id"]');
                    const textInput = row.querySelector('input[type="text"]');
                    const hiddenFalse = row.querySelector('input[type="hidden"][name*=".IsCorrect"]');
                    const checkbox = row.querySelector('input[type="checkbox"]');

                    if (hiddenId) hiddenId.name = `Options[${index}].Id`;
                    if (textInput) textInput.name = `Options[${index}].Text`;
                    if (hiddenFalse) hiddenFalse.name = `Options[${index}].IsCorrect`;
                    if (checkbox) checkbox.name = `Options[${index}].IsCorrect`;
                });
            }

            addOptionBtn.addEventListener("click", function () {
                const index = optionsContainer.querySelectorAll(".option-row").length;

                const html = `
                    <div class="row g-2 align-items-center mb-2 option-row">
                        <input type="hidden" name="Options[${index}].Id" value="0" />

                        <div class="col-md-8">
                            <input name="Options[${index}].Text"
                                   class="form-control"
                                   placeholder="Текст на отговора" />
                        </div>

                        <div class="col-md-2">
                            <div class="form-check mt-2">
                                <input type="hidden" name="Options[${index}].IsCorrect" value="false" />
                                <input type="checkbox"
                                       name="Options[${index}].IsCorrect"
                                       value="true"
                                       class="form-check-input" />
                                <label class="form-check-label">Верен</label>
                            </div>
                        </div>

                        <div class="col-md-2 text-end">
                            <button type="button" class="btn btn-outline-danger remove-option">Премахни</button>
                        </div>
                    </div>
                `;

                optionsContainer.insertAdjacentHTML("beforeend", html);
            });

            document.addEventListener("click", function (e) {
                if (e.target.classList.contains("remove-option")) {
                    e.target.closest(".option-row").remove();
                    reindexOptions();
                }
            });
        </script>
}