@model BeReadyForExam.ViewModel.Question.BulkCreateQuestionsViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Добавяне на въпроси</h2>
    @{
        ViewData["BackController"] = "Exam";
        ViewData["BackAction"] = "Index";
        ViewData["BackText"] = "Назад към тестовете";
    }
    <partial name="_BackButton" />
</div>
<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="ExamId" />

    <div id="questions-container">
        @for (int i = 0; i < Model.Questions.Count; i++)
        {
                <div class="card mb-3 question-block">
                    <div class="card-body">
                        <label>Въпрос</label>
                        <input asp-for="Questions[i].Text" class="form-control mb-2" />

                        <div>
                            <label>Отговори:</label>

                        @for (int j = 0; j < Model.Questions[i].Options.Count; j++)
                        {
                                    <div class="d-flex gap-2 mb-2">
                                        <input asp-for="Questions[i].Options[j].Text" class="form-control" />

                                        <input type="checkbox"
                                               asp-for="Questions[i].Options[j].IsCorrect" />
                                        <span>✔</span>
                                    </div>
                        }
                        </div>
                    </div>
                </div>
        }
    </div>

    <button type="button" class="btn btn-outline-primary" onclick="addQuestion()">
        ➕ Добави въпрос
    </button>

    <button type="submit" class="btn btn-primary">
        💾 Запази всички
    </button>
</form>
