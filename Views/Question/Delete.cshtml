@model BeReadyForExam.Models.Question

@{
    ViewData["Title"] = "Изтриване на въпрос";
}

<div class="container mt-4">
    <div class="card shadow-lg rounded-4 border-danger">
        <div class="card-header bg-danger text-white">
            <h3>🗑 Изтриване на въпрос</h3>
        </div>

        <div class="card-body">
            <h5>Сигурен ли си, че искаш да изтриеш този въпрос?</h5>

            <div class="alert alert-warning mt-3">
                <strong>@Model.Text</strong>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger">
                    Да, изтрий
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Отказ
                </a>
            </form>
        </div>
    </div>
</div>