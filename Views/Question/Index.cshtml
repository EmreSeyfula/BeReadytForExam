@model IEnumerable<BeReadyForExam.Models.Question>

@{
    ViewData["Title"] = "Въпроси";
    var examId = ViewBag.ExamId as int?;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">📚 Въпроси</h2>

            @if (examId != null)
            {
                    <div class="text-muted small">
                        Филтрирани по TestId: <strong>@examId</strong>
                    </div>
            }
        </div>

        <div class="d-flex gap-2">
            @if (examId != null)
            {
                    <a asp-action="Create" asp-route-examId="@examId" class="btn btn-success">
                        ➕ Създай въпрос
                    </a>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Покажи всички
                    </a>
            }
            else
            {
                    <a asp-action="Create" class="btn btn-success">➕ Създай въпрос</a>
            }
        </div>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Текст</th>
                <th>Тест</th>
                <th>Тема</th>
                <th width="220">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var q in Model)
            {
                    <tr>
                        <td>@q.Text</td>
                        <td>@q.Exam?.Title</td>
                        <td>@q.Exam?.Topic?.Name</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@q.Id" class="btn btn-warning btn-sm">✏️ Редактирай</a>
                            <a asp-action="Delete" asp-route-id="@q.Id" class="btn btn-danger btn-sm">🗑 Изтрий</a>
                        </td>
                    </tr>
            }
        </tbody>
    </table>
</div>